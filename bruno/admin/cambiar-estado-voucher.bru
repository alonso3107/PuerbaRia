meta {
  name: Cambiar estado de voucher
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/api/v1/admin/vouchers/1/estado
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "estado": "VALIDADO"
  }
}

docs {
  Estados permitidos: VALIDADO o RECHAZADO. Cambiar el 1 de la URL por el id del voucher.
}
