tests {
  test("devuelve paquetes", function() {
    expect(res.status).to.equal(200);
    expect(res.body).to.be.an("array").that.is.not.empty;
    expect(res.body[0].incluye).to.be.an("array").that.is.not.empty;
  });
}

docs {
